
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model CryptoLoginNonce {
  userId  String   @unique
  nonce   String
  expires DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  regId     Int?
  metaunityId String? @unique
  wallet_address String @unique
  isRegistered Boolean @default(false)
  sponsor_address String?
  directTeam   Int @default(0)
  totalTema    Int  @default(0)
  directTeamTable DirectTeam[]
  totalTeamTable TotalTeam[]
  cryptoLoginNonce       CryptoLoginNonce?
  accounts  Account[]
  sessions Session[]
  packages Package[]
  levelIncome LevelIncome[]
  matrixIncome MatrixIncome[]
  matrixTree   MatrixTree[]
  nftBonusHistory        NFTBonusHistory[]
  currentNFTs            UserNFTs[]
  nftTransferHistory     NFTTransferHistory[]
  nftClaimedHistory      NFTClaimedHistory[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}





model DirectTeam {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet_address String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, wallet_address])
}


model TotalTeam {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet_address String
  generational_level Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, wallet_address])
}


model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([token])
  @@map("session")
}

model Package {
  id          String   @id @default(cuid())
  packageNumber        Int
  amount       Int
  userId      String
  chainid Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  packageBuyTranxHash String @unique
}


model LevelIncome {
  id          String   @id @default(cuid())
  toUserWalletAddress String
  fromUserWalletAddress String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageNumber Int
  amount       String
  level        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MatrixIncome {
  id          String   @id @default(cuid())
  toUserWalletAddress String
  fromUserWalletAddress String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageNumber Int
  amount       String
  chainid Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MatrixTree {
  id          String   @id @default(cuid())
  chainId     Int
  wallet_address String
  upline_address String
  amount       String
  position    String
  userId      String
  packageNumber Int?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}


model NFTTransferHistory {
  id                      String @id @default(cuid())
  userId                  String
  tokenType               Int
  tokenId                 Int
  receiver_wallet_address String
  user                    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NFTBonusHistory {
  id              String   @id @default(cuid())
  userId          String
  tokenId         Int
  tokenType       Int
  bonusAmount     Float
  claminedDate    DateTime
  bonusLaunchDate DateTime
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}



model UserNFTs {
  id          String      @id @default(cuid())
  userId      String
  tokenType   Int
  tokenId     Int
  mintDate    DateTime
  royaltNFTId String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  royaltNFTS  RoyaltyNFTs @relation(fields: [royaltNFTId], references: [id], onDelete: Cascade)

  @@map("UserNFTs")
}


model RoyaltyNFTs {
  id         String     @id @default(cuid())
  tokenType  Int
  tokenId    Int
  tokenCount Int        @default(0)
  nfts       UserNFTs[]

  @@map("RoyaltyNFTs")
}
model NFTClaimedHistory {
  id              String   @id @default(cuid())
  userId          String
  tokenId         Int
  tokenType       Int
  claimedDate     DateTime
  claimedAmount   String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}